build-win-native/msys64
# Embedded toolchain dirs warmup.bat builds on Windows hosts. They
# only exist on aws-dev-win:/cygdrive/c/dev/, never in the local
# repo. Listed here so `rsync --filter=':- .gitignore' --delete`
# preserves them; a missing entry here = `--delete` wipes them and
# recovery requires re-running warmup.bat (20-30 min, ~10GB of
# downloads). See the rsync-excludes memory for the post-mortem.
build-win-native/cuda
build-win-native/dist
build-win-native/mingit
build-win-native/7zip
build-win-native/msvc
build-win-native/jupyter
build-win-native/fast_check
build-win-native/python_full
.claude/
.venv/
# build-all.sh installs the maturin-built PyO3 wheel here so two
# worktrees on the same host don't clobber each other's _ppf_cts_py
# through the shared venv site-packages. Path is the same on every
# tree; the gitignore matches at the repo root only.
/.tree-pyo3/
