# Build outputs rebuilt inside the container.
target/
.tree-pyo3/
# Per-tree venv created by `python3 -m venv` on the host; the
# container creates its own via `warmup.py --skip-confirmation`.
.venv/

# Examples runtime / cache (re-fetched in the container on demand by
# the notebooks that need them).
examples/cache/
examples/.virtual_documents/
examples/.ipynb_checkpoints/
examples/_*

# Windows-only embedded toolchain. None of this is consumable by the
# Linux container; warmup.bat populates these on Windows hosts only.
build-win-native/python/
build-win-native/python_full/
build-win-native/cuda/
build-win-native/downloads/
build-win-native/deps/
build-win-native/rust/
build-win-native/msvc/
build-win-native/msys64/
build-win-native/mingit/
build-win-native/7zip/
build-win-native/jupyter/
build-win-native/fast_check/
build-win-native/dist/
build-win-native/temp_ffmpeg/
build-win-native/ffmpeg/
build-win-native/ci/

# Local tooling / IDE state.
.vscode/
.idea/

# Compiled python / OS / log clutter.
__pycache__/
*.pyc
*.pyo
.DS_Store
*.log
report.json
node_modules/
